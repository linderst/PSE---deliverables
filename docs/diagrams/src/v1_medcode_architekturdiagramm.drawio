        <mxCell id="us_note" parent="1" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;size=15;fillColor=#FFFDE7;strokeColor=#F57F17;fontSize=11;align=left;verticalAlign=top;spacingLeft=10;spacingTop=10;spacingRight=5;" value="&lt;b&gt;User Stories:&lt;/b&gt;&lt;br&gt;US1: ICD-Code → Erklärung (einfache Sprache)&lt;br&gt;US2: Diagnose → Facharzt-Empfehlung&lt;br&gt;US3: Behandlung → Verhaltensregeln&lt;br&gt;US4: Semantische Suche (ungenaue Begriffe)&lt;br&gt;&lt;br&gt;&lt;b&gt;Zusatz:&lt;/b&gt; Verweis auf extradoc.ch (Marketing)" vertex="1">
